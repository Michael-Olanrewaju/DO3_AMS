# Server Port
PORT=3001

# Database Type: 'sqlite' for local, 'mysql' for cPanel
DB_TYPE=sqlite

# MySQL Configuration (only needed when DB_TYPE=mysql)
DB_HOST=localhost
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=thams_db

# JWT Secret
JWT_SECRET=thams-secret-key-2024

# Email Configuration
